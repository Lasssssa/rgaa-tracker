# Copy this file to `.env` (next to compose.yml) and adjust for your
# environment. Docker Compose reads it automatically to fill the ${...}
# placeholders in compose.yml. `.env` is gitignored.

# --- Base images ------------------------------------------------------------
# Override to pull from an internal / mirrored / hardened registry.
PYTHON_IMAGE=python:3.12-slim
NODE_IMAGE=node:22-slim
POSTGRES_IMAGE=postgres:16-alpine

# --- Corporate proxy (build + runtime) --------------------------------------
# Leave empty for a direct connection. NO_PROXY should list internal hosts that
# must be reached without the proxy (the compose services, and any internal
# vLLM endpoint).
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,db,api,frontend

# --- vLLM / LLM extraction --------------------------------------------------
# See backend/.env.example for what each setting does.
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=
VLLM_API_KEY=EMPTY
LLM_GUIDED_JSON=false
LLM_MAX_OUTPUT_TOKENS=16384
