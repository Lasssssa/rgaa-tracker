DATABASE_URL=postgresql://postgres:postgres@db:5432/rgaa_tracker

# vLLM server used to extract errors from the audit PDF (OpenAI-compatible API).
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=
VLLM_API_KEY=EMPTY
# Set to true only if the server supports response_format json_schema.
LLM_GUIDED_JSON=false
LLM_MAX_OUTPUT_TOKENS=4096
# How many times to call the model to get valid JSON (each retry re-prompts
# with a repair hint). Raise it for less deterministic models.
LLM_MAX_ATTEMPTS=4
